{% extends 'admin/base.html.twig' %}

{% block title %}Gérance Locative - Gestion{% endblock %}

{% block content %}
<div style="max-width: 1100px; margin: 0 auto; display: flex; flex-direction: column; gap: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
    <h1 style="font-size: 1.6rem; color: #232946; font-weight: 700;">Gérance Locative</h1>
    <div style="display: flex; gap: 10px;">
      <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">🏠 Dashboard</a>
    </div>
  </div>

  {# 1. Invalider des rubriques #}
  <div style="background:#fff;border-radius:15px;box-shadow:0 8px 32px rgba(0,0,0,0.08);border:1px solid #eef2f7;padding:24px;">
    <h2 style="font-size:1.2rem;color:#232946;font-weight:700;margin-bottom:16px;">Invalider des rubriques :</h2>
    <form method="get" action="{{ path('admin_gerance_locative') }}" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <label for="gerance_contrat_invalider" style="font-weight:600;color:#232946;font-size:0.9rem;">Contrat :</label>
      <input type="text" id="gerance_contrat_invalider" name="contrat" value="{{ contrat_recherche|default('') }}" placeholder="Numéro de contrat" style="padding:10px 12px;border:1.5px solid #e2e8f0;border-radius:8px;min-width:200px;">
      <button type="submit" class="btn">Rechercher</button>
    </form>
    {% if rubriques is defined %}
      <div style="margin-top:16px;padding-top:16px;border-top:1px solid #eef2f7;">
        {% if rubriques|length > 0 %}
          <form method="post" action="{{ path('admin_gerance_locative_mettre_a_jour') }}" id="form-invalider-rubriques">
            <input type="hidden" name="_token" value="{{ csrf_token('gerance_locative_mettre_a_jour') }}">
            <input type="hidden" name="contrat" value="{{ contrat_recherche|e('html_attr') }}">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px 20px;margin-bottom:14px;">
              {% for r in rubriques %}
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:0.9rem;">
                  <input type="checkbox" name="rubriques[]" value="{{ r.code|e('html_attr') }}" {{ r.selected ? 'checked' : '' }}>
                  <span>{{ r.code }}</span>
                </label>
              {% endfor %}
            </div>
            <button type="submit" class="btn btn-secondary">Mettre à jour</button>
          </form>
        {% else %}
          <p style="color:#64748b;font-size:0.9rem;">Aucune rubrique trouvée pour ce contrat.</p>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {# 2. Diagnostic Liquidation (pb eau) #}
  <div style="background:#fff;border-radius:15px;box-shadow:0 8px 32px rgba(0,0,0,0.08);border:1px solid #eef2f7;padding:24px;">
    <h2 style="font-size:1.2rem;color:#232946;font-weight:700;margin-bottom:16px;">Diagnostic Liquidationimage.png</h2>
    <form method="get" action="{{ path('admin_gerance_locative') }}" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:12px;">
      <label for="gerance_contrat_diag" style="font-weight:600;color:#232946;font-size:0.9rem;">Contrat :</label>
      <input type="text" id="gerance_contrat_diag" name="contrat_diag" value="{{ contrat_diag|default('') }}" placeholder="Numéro de contrat" style="padding:10px 12px;border:1.5px solid #e2e8f0;border-radius:8px;min-width:200px;">
      <button type="submit" class="btn">Diagnostiquer</button>
    </form>

    {% if diag is defined %}
      <div style="margin-bottom:12px;font-size:0.9rem;color:#1f2933;">
        {% if diag.finContrat %}
          Date de fin de contrat : {{ diag.finContrat|date('d/m/Y') }}
        {% else %}
          Date de fin de contrat : inconnue
        {% endif %}
      </div>

      {# Relevés eau (ECREL) #}
      <div style="margin-bottom:16px;">
        <h3 style="font-size:1rem;font-weight:600;color:#232946;margin-bottom:4px;">Index (ECREL)</h3>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:0.85rem;border:1px solid #e2e8f0;">
            <thead>
              <tr>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">COMPTEUR</th>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">OBSERVATION</th>
                <th style="text-align:right;padding:2px 6px;border-bottom:1px solid #e2e8f0;">INDEX_RLV</th>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">DATE_RLV</th>
              </tr>
            </thead>
            <tbody>
              {% for row in diag.releves %}
                <tr>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.COMPTEUR }}</td>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.OBSERVATION }}</td>
                  <td style="padding:2px 6px;text-align:right;border-top:1px solid #f1f5f9;">{{ row.INDEX_RLV }}</td>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.DATE_RLV }}</td>
                </tr>
              {% else %}
                <tr><td colspan="4" style="color:#64748b;font-size:0.85rem;padding:2px 6px;border-top:1px solid #f1f5f9;">Aucun relevé trouvé.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# Consommations (ECCON) #}
      <div style="margin-bottom:16px;">
        <h3 style="font-size:1rem;font-weight:600;color:#232946;margin-bottom:4px;">Consommations (ECCON)</h3>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:0.85rem;border:1px solid #e2e8f0;">
            <thead>
              <tr>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">COMPTEUR</th>
                <th style="text-align:right;padding:2px 6px;border-bottom:1px solid #e2e8f0;">CONSOMMATION</th>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">DATE_RLV</th>
                <th style="text-align:right;padding:2px 6px;border-bottom:1px solid #e2e8f0;">NO_LIQUIDATION</th>
              </tr>
            </thead>
            <tbody>
              {% for row in diag.consommations %}
                <tr>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.COMPTEUR }}</td>
                  <td style="padding:2px 6px;text-align:right;border-top:1px solid #f1f5f9;">{{ row.CONSOMMATION }}</td>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.DATE_RLV }}</td>
                  <td style="padding:2px 6px;text-align:right;border-top:1px solid #f1f5f9;">{{ row.NO_LIQUIDATION }}</td>
                </tr>
              {% else %}
                <tr><td colspan="4" style="color:#64748b;font-size:0.85rem;padding:2px 6px;border-top:1px solid #f1f5f9;">Aucune consommation trouvée.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# Rubriques (GLRUC) + groupe de prix #}
      <div>
        <h3 style="font-size:1rem;font-weight:600;color:#232946;margin-bottom:4px;">Rubriques (GLRUC)</h3>
        <div style="overflow-x:auto;margin-bottom:8px;">
          <table style="width:100%;border-collapse:collapse;font-size:0.85rem;border:1px solid #e2e8f0;">
            <thead>
              <tr>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">GLRUB_COD</th>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">GLGPR_COD</th>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">GLRUC_DTD</th>
                <th style="text-align:left;padding:2px 6px;border-bottom:1px solid #e2e8f0;">GLRUC_DTF</th>
                <th style="text-align:right;padding:2px 6px;border-bottom:1px solid #e2e8f0;">GLRUC_MNT</th>
              </tr>
            </thead>
            <tbody>
              {% for row in diag.rubriques %}
                <tr>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.GLRUB_COD }}</td>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.GLGPR_COD }}</td>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.GLRUC_DTD }}</td>
                  <td style="padding:2px 6px;border-top:1px solid #f1f5f9;">{{ row.GLRUC_DTF }}</td>
                  <td style="padding:2px 6px;text-align:right;border-top:1px solid #f1f5f9;">{{ row.GLRUC_MNT }}</td>
                </tr>
              {% else %}
                <tr><td colspan="5" style="color:#64748b;font-size:0.85rem;padding:2px 6px;border-top:1px solid #f1f5f9;">Aucune rubrique trouvée.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        {% if diag.gpePrix is not empty %}
          <form method="post" action="{{ path('admin_gerance_locative_diag_gpe_prix') }}" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <input type="hidden" name="_token" value="{{ csrf_token('gerance_locative_diag_gpe_prix') }}">
            <input type="hidden" name="contrat_diag" value="{{ contrat_diag|e('html_attr') }}">
            <label for="gpe_prix" style="font-weight:600;color:#232946;font-size:0.9rem;">Groupe de prix de l'ESI :</label>
            <select id="gpe_prix" name="gpe_prix" class="search-input" style="min-width:220px;padding:8px 10px;">
              {% for opt in diag.gpePrix %}
                <option value="{{ opt.VALUE }}">{{ opt.LABEL }}</option>
              {% endfor %}
            </select>
            <button type="submit" class="btn btn-secondary">Rappatrier le groupe de prix de l'ESI</button>
          </form>
        {% endif %}
      </div>
    {% endif %}
  </div>

</div>
{% endblock %}
