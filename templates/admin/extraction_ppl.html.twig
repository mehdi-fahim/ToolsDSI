{% extends 'admin/base.html.twig' %}

{% block title %}Extraction PPL{% endblock %}

{% block content %}
<div class="admin-container">
    <div class="admin-header">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
            <div>
                <h1>📤 Extraction PPL</h1>
                <p>Extractions quote-parts, OD, TOPNU, facturation eau et clés de répartition.</p>
            </div>
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">← Retour</a>
        </div>
    </div>

    <div class="admin-content" style="display:flex;flex-direction:column;gap:20px;">
        {% if error %}
            <div style="background:#fed7d7;color:#c53030;padding:12px 16px;border-radius:8px;">
                {{ error }}
            </div>
        {% endif %}

        <section style="padding-bottom:18px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Quote-parts</h2>
            <form method="POST" action="{{ path('admin_extraction_ppl') }}" data-turbo="false" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
                <input type="hidden" name="action" value="quote_parts">
                <div>
                    <label for="periode" style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">Période (GLPER_COD)</label>
                    <input type="text" id="periode" name="periode" class="search-input" style="min-width:180px;" value="{{ periode }}" required>
                </div>
                <button type="submit" class="btn btn-success">⬇️ Extraire</button>
            </form>
        </section>

        <section style="padding-bottom:18px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Liste OD</h2>
            <form method="POST" action="{{ path('admin_extraction_ppl') }}" data-turbo="false" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
                <input type="hidden" name="action" value="liste_od">
                <div>
                    <label for="date_liste_od" style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">Date d'échéance à partir du</label>
                    <input type="date" id="date_liste_od" name="date_liste_od" class="search-input" value="{{ dateListeOd }}" required>
                </div>
                <button type="submit" class="btn btn-success">⬇️ Extraire</button>
            </form>
        </section>

        <section style="padding-bottom:18px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Extraire le tableau des allocataires</h2>
            <form method="POST" action="{{ path('admin_extraction_ppl') }}" data-turbo="false">
                <input type="hidden" name="action" value="topnu_alloc">
                <button type="submit" class="btn btn-success">⬇️ Extraire</button>
            </form>
        </section>

        <section style="padding-bottom:18px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Extraction liste allocataire</h2>
            <form method="POST" action="{{ path('admin_extraction_ppl') }}" data-turbo="false">
                <input type="hidden" name="action" value="topnu_detail">
                <button type="submit" class="btn btn-success">⬇️ Extraire</button>
            </form>
        </section>

        <section style="padding-bottom:18px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Facturation eau mensuelle</h2>
            <form method="POST" action="{{ path('admin_extraction_ppl') }}" data-turbo="false" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
                <input type="hidden" name="action" value="fact_eau">
                <div>
                    <label for="mois_eau" style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">Mois / année eau à partir du</label>
                    <input type="date" id="mois_eau" name="mois_eau" class="search-input" value="{{ moisEau }}" required>
                </div>
                <button type="submit" class="btn btn-success">⬇️ Extraire</button>
            </form>
        </section>

        <section>
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Clés de répartition EDF</h2>
            <form method="POST" action="{{ path('admin_extraction_ppl') }}" data-turbo="false">
                <input type="hidden" name="action" value="cles_repartition">
                <button type="submit" class="btn btn-success">⬇️ Extraire</button>
            </form>
        </section>
    </div>
</div>
{% endblock %}
