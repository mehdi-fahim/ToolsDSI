{% extends 'admin/base.html.twig' %}

{% block title %}Listing{% endblock %}

{% block content %}
<div class="admin-container">
    <div class="admin-header">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
            <div>
                <h1>📑 Listing</h1>
                <p>Recherches et extractions de listings locataires.</p>
            </div>
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">← Retour</a>
        </div>
    </div>

    <div class="admin-content" style="display:flex;flex-direction:column;gap:24px;">
        {% if error %}
            <div style="background:#fed7d7;color:#c53030;padding:12px 16px;border-radius:8px;">
                {{ error }}
            </div>
        {% endif %}

        <section style="padding-bottom:20px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.1rem;color:#2d3748;margin-bottom:12px;">Chercher un groupe par le libellé de la rue</h2>
            <form method="POST" action="{{ path('admin_extraction_listing') }}" data-turbo="false" style="display:flex;flex-wrap:wrap;gap:16px;align-items:flex-end;">
                <input type="hidden" name="action" value="chercher_groupe">
                <div>
                    <label for="nom_rue" style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">Libellé de rue</label>
                    <input
                        type="text"
                        id="nom_rue"
                        name="nom_rue"
                        class="search-input"
                        style="min-width:280px;"
                        value="{{ nomRue }}"
                        required
                        placeholder="Ex. REPUBLIQUE"
                    >
                </div>
                <button type="submit" class="btn">Chercher</button>
            </form>

            {% if groupResults is not null %}
                <div style="margin-top:18px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
                    <p style="color:#4a5568;">{{ groupResults|length }} résultat(s)</p>
                    {% if groupResults|length > 0 %}
                        <form method="POST" action="{{ path('admin_extraction_listing') }}" data-turbo="false">
                            <input type="hidden" name="action" value="export_groupe_rue">
                            <input type="hidden" name="nom_rue" value="{{ nomRue }}">
                            <button type="submit" class="btn btn-success">⬇️ Exporter en CSV</button>
                        </form>
                    {% endif %}
                </div>

                {% if groupResults|length > 0 %}
                    <div class="table-container" style="margin-top:12px;">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Code ESI</th>
                                    <th>Type</th>
                                    <th>Libellé</th>
                                    <th>Adresse</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in groupResults %}
                                    <tr>
                                        <td>{{ row.PAESI_CODEXT ?? row.paesi_codext ?? '' }}</td>
                                        <td>{{ row.PANES_COD ?? row.panes_cod ?? '' }}</td>
                                        <td>{{ row.PAESI_LIB ?? row.paesi_lib ?? '' }}</td>
                                        <td>{{ row.ADRESSE ?? row.adresse ?? '' }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            {% endif %}
        </section>

        <section style="padding-bottom:20px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.1rem;color:#2d3748;margin-bottom:12px;">Extraction listing locataire par groupe</h2>
            <form method="POST" action="{{ path('admin_extraction_listing') }}" data-turbo="false" style="display:flex;flex-wrap:wrap;gap:16px;align-items:flex-end;">
                <input type="hidden" name="action" value="liste_locataire">
                <div>
                    <label for="groupe" style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">Groupe</label>
                    <input
                        type="text"
                        id="groupe"
                        name="groupe"
                        class="search-input"
                        style="min-width:180px;"
                        value="{{ groupe }}"
                        required
                        placeholder="Préfixe ESI"
                    >
                </div>
                <label style="display:flex;align-items:center;gap:8px;color:#4a5568;font-weight:600;">
                    <input type="checkbox" name="inclure_logement" value="1" {{ inclureLogement ? 'checked' : '' }}>
                    Inclure les informations logement
                </label>
                <button type="submit" class="btn btn-success">⬇️ Rechercher</button>
            </form>
        </section>

        <section>
            <h2 style="font-size:1.1rem;color:#2d3748;margin-bottom:12px;">Listing des relogés (&gt;= {{ anneeReloges }})</h2>
            <p style="color:#718096;margin-bottom:12px;">Cet export peut prendre plusieurs minutes selon le volume de données.</p>
            <form method="POST" action="{{ path('admin_extraction_listing') }}" data-turbo="false">
                <input type="hidden" name="action" value="reloges">
                <button type="submit" class="btn btn-success">⬇️ Extraire</button>
            </form>
        </section>
    </div>
</div>
{% endblock %}
