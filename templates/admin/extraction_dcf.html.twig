{% extends 'admin/base.html.twig' %}

{% block title %}Extraction DCF{% endblock %}

{% block content %}
<div class="admin-container">
    <div class="admin-header">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
            <div>
                <h1>📤 Extraction DCF</h1>
                <p>Rubriques mensuelles, contrôle ESI et extractions DCF encaissement, facturation, dettes et loyers.</p>
            </div>
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">← Retour</a>
        </div>
    </div>

    <div class="admin-content" style="display:flex;flex-direction:column;gap:20px;">
        {% if error %}
            <div style="background:#fed7d7;color:#c53030;padding:12px 16px;border-radius:8px;">
                {{ error }}
            </div>
        {% endif %}

        {% if success %}
            <div style="background:#c6f6d5;color:#22543d;padding:12px 16px;border-radius:8px;">
                {{ success }}
            </div>
        {% endif %}

        {% if detailResult %}
            <div style="background:#ebf8ff;color:#2b6cb0;padding:12px 16px;border-radius:8px;">
                {{ detailResult }}
            </div>
        {% endif %}

        <section style="padding:18px;border:1px solid #e2e8f0;border-radius:12px;background:#fff;">
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:14px;">Paramètres d'extraction</h2>
            <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
                <div>
                    <label for="annee" style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">Année</label>
                    <input type="number" id="annee" name="annee" class="search-input" min="2000" max="2100" value="{{ annee }}" required>
                </div>
                <div>
                    <label for="mois" style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">Mois</label>
                    <input type="number" id="mois" name="mois" class="search-input" min="1" max="12" value="{{ mois }}" required>
                </div>
                <div>
                    <label style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">Utilisateur</label>
                    <input type="text" class="search-input" value="{{ userId }}" disabled style="min-width:160px;background:#f7fafc;">
                </div>
            </form>
        </section>

        <section style="padding-bottom:18px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Extraction mensuelle des rubriques</h2>
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
                <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                    <input type="hidden" name="action" value="ruban_generate">
                    <input type="hidden" name="annee" value="{{ annee }}">
                    <input type="hidden" name="mois" value="{{ mois }}">
                    <button type="submit" class="btn btn-primary">Générer le fichier</button>
                </form>
                <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                    <input type="hidden" name="action" value="ruban_export">
                    <input type="hidden" name="annee" value="{{ annee }}">
                    <input type="hidden" name="mois" value="{{ mois }}">
                    <button type="submit" class="btn btn-success">⬇️ Obtenir le fichier Excel</button>
                </form>
            </div>
        </section>

        <section style="padding-bottom:18px;border-bottom:1px solid #e2e8f0;">
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Détail d'un ESI sur la période donnée</h2>
            <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
                <input type="hidden" name="action" value="detail_esi">
                <input type="hidden" name="annee" value="{{ annee }}">
                <input type="hidden" name="mois" value="{{ mois }}">
                <div>
                    <label for="esi" style="display:block;font-weight:600;color:#4a5568;margin-bottom:6px;">ESI</label>
                    <input type="text" id="esi" name="esi" class="search-input" value="{{ esi }}" style="min-width:220px;" required>
                </div>
                <button type="submit" class="btn btn-secondary">Afficher le détail</button>
            </form>
        </section>

        <section>
            <h2 style="font-size:1.05rem;color:#2d3748;margin-bottom:12px;">Extractions encaissement, facturation, dettes, loyers</h2>
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                    <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                        <input type="hidden" name="action" value="encaissement_generate">
                        <input type="hidden" name="annee" value="{{ annee }}">
                        <input type="hidden" name="mois" value="{{ mois }}">
                        <button type="submit" class="btn btn-primary">Générer Encaissement</button>
                    </form>
                    <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                        <input type="hidden" name="action" value="encaissement_export">
                        <input type="hidden" name="annee" value="{{ annee }}">
                        <input type="hidden" name="mois" value="{{ mois }}">
                        <button type="submit" class="btn btn-success">⬇️ Obtenir le fichier encaissement</button>
                    </form>
                </div>

                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                    <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                        <input type="hidden" name="action" value="facturation_generate">
                        <input type="hidden" name="annee" value="{{ annee }}">
                        <input type="hidden" name="mois" value="{{ mois }}">
                        <button type="submit" class="btn btn-primary">Générer Facturation</button>
                    </form>
                    <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                        <input type="hidden" name="action" value="facturation_export">
                        <input type="hidden" name="annee" value="{{ annee }}">
                        <input type="hidden" name="mois" value="{{ mois }}">
                        <button type="submit" class="btn btn-success">⬇️ Obtenir le fichier facturation</button>
                    </form>
                </div>

                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                    <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                        <input type="hidden" name="action" value="dettes_generate">
                        <input type="hidden" name="annee" value="{{ annee }}">
                        <input type="hidden" name="mois" value="{{ mois }}">
                        <button type="submit" class="btn btn-primary">Générer Dettes</button>
                    </form>
                    <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                        <input type="hidden" name="action" value="dettes_export">
                        <input type="hidden" name="annee" value="{{ annee }}">
                        <input type="hidden" name="mois" value="{{ mois }}">
                        <button type="submit" class="btn btn-success">⬇️ Obtenir le fichier dettes</button>
                    </form>
                </div>

                <div style="display:flex;gap:12px;flex-wrap:wrap;">
                    <form method="POST" action="{{ path('admin_extraction_dcf') }}" data-turbo="false">
                        <input type="hidden" name="action" value="loyers_export">
                        <input type="hidden" name="annee" value="{{ annee }}">
                        <input type="hidden" name="mois" value="{{ mois }}">
                        <button type="submit" class="btn btn-success">⬇️ Obtenir le fichier loyers (Année)</button>
                    </form>
                </div>
            </div>
        </section>
    </div>
</div>
{% endblock %}
